# Server
NODE_ENV=development
PORT=5000

# Database
MONGO_MASTER_URI=mongodb://localhost:27017/pms_master
MONGO_TENANT_BASE_URI=mongodb://localhost:27017

# Auth
JWT_SECRET=change_me_to_a_strong_secret
JWT_EXPIRES_IN=7d
SESSION_SECRET=change_me_to_a_strong_session_secret
# Optional cookie name override (defaults: __Host-pms-sid in production, pms-sid in development)
# SESSION_COOKIE_NAME=

# App URLs
APP_BASE_URL=http://localhost:5000

# PayFast
PAYFAST_MERCHANT_ID=
PAYFAST_SECURED_KEY=
PAYFAST_TOKEN_URL=https://ipguat.apps.net.pk/Ecommerce/api/Transaction/GetAccessToken
PAYFAST_CHECKOUT_URL=https://ipguat.apps.net.pk/Ecommerce/api/Transaction/PostTransaction
PAYFAST_SUCCESS_URL=http://localhost:5000/api/payments/payfast/success
PAYFAST_FAILURE_URL=http://localhost:5000/api/payments/payfast/cancel
PAYFAST_CANCEL_URL=http://localhost:5000/api/payments/payfast/cancel

# Optional: restrict PayFast IPN source IPs (comma-separated)
# PAYFAST_IP_ALLOWLIST=1.2.3.4,5.6.7.8
